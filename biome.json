{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": [
      "docs/js/**/*.js",
      "docs/css/**/*.css",
      "test/**/*.js",
      "e2e/**/*.js"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": { "preset": "recommended" }
  },
  "formatter": { "enabled": false },
  "overrides": [
    {
      "includes": ["docs/css/**/*.css"],
      "formatter": { "enabled": true }
    }
  ]
}
